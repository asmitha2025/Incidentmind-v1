# IncidentMind — Environment Variables
# Copy this to .env for local development
# In HF Spaces: add these under Settings → Variables and Secrets

# HuggingFace router endpoint
API_BASE_URL=https://router.huggingface.co/v1

# Model to use for baseline agent
MODEL_NAME=meta-llama/Llama-3.3-70B-Instruct

# Your HuggingFace token — get it from hf.co/settings/tokens
HF_TOKEN=your_hf_token_here

# Environment URL (used by inference.py when running against deployed Space)
# Leave as localhost for local testing
ENV_URL=http://localhost:7860
